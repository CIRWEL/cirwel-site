---
// PageFooter — single source of truth for the colophon + records block.
// Build-time provenance is computed here so the three pages that mount
// this component (/, /ecosystem, /404) cannot drift apart on rebuild.
const buildSha  = (process.env.CF_PAGES_COMMIT_SHA ?? '').slice(0, 8) || 'local';
const buildTime = new Date().toISOString().slice(0, 16).replace('T', ' ') + ' UTC';
---
<footer class="px-6 lg:px-12 max-w-screen-xl mx-auto py-12 grid grid-cols-12 gap-6 text-sm text-stone">
  <div class="col-span-12 md:col-span-4">
    <p class="display smcp text-base font-medium text-ink mb-2">CIRWEL Systems</p>
    <p>Independent research operator.</p>
  </div>
  <div class="col-span-12 md:col-span-4">
    <p class="label mb-3 text-ink">Records</p>
    <p>
      ORCID <a href="https://orcid.org/0009-0006-7544-2374" class="font-mono">0009-0006-7544-2374</a><br/>
      DOI <a href="https://doi.org/10.5281/zenodo.19647159" class="font-mono">10.5281/zenodo.19647159</a>
    </p>
  </div>
  <div class="col-span-12 md:col-span-4 md:text-right">
    <p class="label mb-3 text-ink">© 2026</p>
    <p>All rights reserved unless noted.<br/>Plugin and paper carry their own licenses.</p>
  </div>

  <div class="col-span-12 mt-8 pt-6 border-t border-sepia/40 label text-stone text-center leading-loose">
    Set in <span class="text-ink">Fraunces</span> &amp; <span class="text-ink">JetBrains Mono</span>
    &middot; cream and oxblood
    &middot; rendered from <span class="text-ink">{buildSha}</span> at <span class="text-ink">{buildTime}</span>
    &middot; under <span class="text-ink">UNITARES</span> governance
    &nbsp;—&nbsp; fin.
  </div>
</footer>
